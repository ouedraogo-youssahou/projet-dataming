# Environment variables for Smart eCommerce Intelligence
# Copy this file to .env and fill in your values

# DeepSeek API Key (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=

# Groq API Key
GROQ_API_KEY=

# Shopify Access Token
SHOPIFY_ACCESS_TOKEN=

# WooCommerce API Credentials
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# PostgreSQL Database
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=secure_password
POSTGRES_HOST=postgres

# Redis
REDIS_PASSWORD=redis_password
REDIS_HOST=redis

# MCP Server
MCP_API_KEY=mcp_api_key

# Jupyter
JUPYTER_TOKEN=jupyter_token

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=pgadmin_password

# Docker Registry (optional, for CI/CD)
DOCKER_USERNAME=
DOCKER_PASSWORD=

# ============================================
# A2A Agents Configuration
# ============================================
USE_REDIS=true
AGENT_MAX_CONCURRENT=5
AGENT_HEARTBEAT_INTERVAL=30

# ============================================
# Scheduler Configuration
# ============================================
SCRAPING_SCHEDULE=0 3 * * *      # Daily at 3 AM
ML_RETRAIN_SCHEDULE=0 4 * * 0    # Weekly Sunday 4 AM
LOG_LEVEL=INFO

# ============================================
# Monitoring Configuration
# ============================================
PROMETHEUS_PORT=9090

# ============================================
# Development (optional)
# ============================================
PYTHON_ENV=development
JUPYTER_TOKEN=dev_token_123