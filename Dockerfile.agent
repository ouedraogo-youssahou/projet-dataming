# ============================================
# Agent Launcher Stage - A2A Agent Cluster
# ============================================

# Use scraper as base (has all scraping deps)
FROM datamining-dashboard:scraper as agent-orchestrator

# Install scheduler & monitoring dependencies
RUN pip install --no-cache-dir \
    apscheduler \
    prometheus-client

# Copy orchestration code
COPY src/scraping/agents/ /app/src/scraping/agents/
COPY src/__main__.py /app/src/__main__.py
COPY src/scheduler/ /app/src/scheduler/
COPY src/monitoring/ /app/src/monitoring/

# Create non-root user for agents
RUN useradd --create-home --shell /bin/bash agentuser && \
    chown -R agentuser:agentuser /app

USER agentuser

# Default: launch agent cluster
CMD ["python", "-m", "src.scraping.agents.main"]
